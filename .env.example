# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── LLM Options (tried in order) ──

# 1. Ollama (local, completely free) — no key needed
#    Just run: ollama pull llama3.2 && ollama serve

# 2. Grok (xAI, requires API key)
#    Get an API key at https://console.x.ai
GROK_API_KEY=""

# 3. Google Gemini (free tier, fallback)
#    Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# 3. OpenAI (paid fallback)
# OPENAI_API_KEY="sk-..."

# Optional: TMDB API Key (free at https://themoviedb.org)
# TMDB_API_KEY=""
